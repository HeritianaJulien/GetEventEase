[MainActivity] --> [navigation/AppNavigation.kt]
[navigation/AppNavigation.kt] --> [ui/screens/HomeScreen.kt]
[navigation/AppNavigation.kt] --> [ui/screens/MatchInterclasseScreen.kt]
[navigation/AppNavigation.kt] --> [ui/screens/SemaineTcoScreen.kt]
[navigation/AppNavigation.kt] --> [ui/screens/PedagogieScreen.kt]
[navigation/AppNavigation.kt] --> [ui/screens/ExcursionScreen.kt]
