[data/model/MatchInterclasse.kt] --> [data/StatusResolver.kt]
[data/model/Excursion.kt] --> [data/StatusResolver.kt]
[data/model/PedagogieFiliere.kt] --> [data/StatusResolver.kt]
[data/model/SemaineTcoActivite.kt] --> [data/StatusResolver.kt]
