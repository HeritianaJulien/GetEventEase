@startuml
package "com.example.geteventease" {
  class MainActivity
  class "GETEventEaseNavHost" as NavHost
  class HomeScreen
  class FakeData <<singleton>>
  class EventCategory <<enumeration>>
  class EventStatus <<enumeration>>
  class StatusResolver <<singleton>>
  class Excursion
  class MatchInterclasse
  class PedagogieFiliere
  class SemaineTcoActivite <<abstract>>
  class HomeMenuCard
  class ContentItemCard
  class DetailComponents
  class StatusBadge
}

package "com.example.geteventease.navigation" {
  class AppNavigation
}

package "com.example.geteventease.data.model" {
  class Sport <<enumeration>>
  class FilierePedagogie <<enumeration>>
  class SemaineActiviteType <<enumeration>>
}

NavHost --> HomeScreen : affiche
NavHost --> FakeData : charge données
NavHost --> MatchInterclasse : utilise
NavHost --> Excursion : utilise
NavHost --> PedagogieFiliere : utilise
NavHost --> SemaineTcoActivite : utilise

MainActivity --> NavHost : contient
HomeScreen --> EventCategory : sélectionne
FakeData --> Excursion : fournit
FakeData --> MatchInterclasse : fournit
FakeData --> PedagogieFiliere : fournit
FakeData --> SemaineTcoActivite : fournit

Excursion --> StatusResolver : status()
MatchInterclasse --> StatusResolver : status()
PedagogieFiliere --> StatusResolver : status()
SemaineTcoActivite --> StatusResolver : status()

SemaineTcoActivite <|-- "Jardinage"
SemaineTcoActivite <|-- "Conference"
SemaineTcoActivite <|-- "AlgoContest"
SemaineTcoActivite <|-- "ConcoursMiniProjet"
SemaineTcoActivite <|-- "Esport"
SemaineTcoActivite <|-- "FinalInterclasse"
SemaineTcoActivite <|-- "GrandeReception"
@enduml

